DATABASE_URL="postgresql://vta:vta_password@localhost:5432/vta_commerce?schema=public"
JWT_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-refresh"
API_PORT=3001
WEB_PORT=3000
WEB_URL="http://localhost:3000"
APP_PUBLIC_URL="http://localhost:3000"
ADMIN_WEB_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
SUPER_ADMIN_EMAIL="admin@vtaerp.com"
SUPER_ADMIN_PASSWORD="Admin@123456"
DATABASE_BACKUP_DIR="backups"
PASSWORD_RESET_URL="http://localhost:3000/reset-password"
PASSWORD_RESET_BASE_URL="http://localhost:3000/reset-password"
PASSWORD_RESET_ALLOWED_HOSTS="vtaerp.com,www.vtaerp.com,localhost"

