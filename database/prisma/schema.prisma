generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  PAUSED
  SUSPENDED
  EXPIRED
  TRIAL
  CANCELLED
  DELETED
}
enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
  ESSENTIAL
  STANDARD
  EXPERT
}
enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  GRACE_PERIOD
  SUSPENDED
  CANCELED
  EXPIRED
}

enum BarcodeType {
  UPC
  EAN
  QR
  CUSTOM
}

enum InventoryMovementType {
  IN
  OUT
  PURCHASE
  SALE
  RETURN
  CANCEL_SALE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  PHYSICAL_COUNT
}

enum TransferStatus {
  DRAFT
  SENT
  RECEIVED
  CANCELLED
}

enum PhysicalInventoryStatus {
  DRAFT
  VALIDATED
  CANCELLED
}

enum StockAlertType {
  LOW_STOCK
  OUT_OF_STOCK
  EXPIRING_SOON
  EXPIRED
}

enum StockAlertStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  RETURNED
}

enum HeldSaleStatus {
  AVAILABLE
  CLAIMED
  FINALIZING
  COMPLETED
  CANCELLED
}
enum SalesDocumentStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CONVERTED
  PAID
  PARTIALLY_PAID
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MIXED
}

enum CashSessionStatus {
  OPEN
  CLOSED
  SUSPENDED
}

enum CashMovementType {
  IN
  OUT
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
  COMPANY
  VIP
  WHOLESALE
  GOVERNMENT
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum StoreStatus {
  ACTIVE
  CLOSED
  INACTIVE
}

enum WarehouseStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum StoreTransferStatus {
  DRAFT
  VALIDATED
  CANCELLED
}

enum BackupStatus {
  SUCCESS
  ERROR
}

enum SecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_BLOCKED
  LOGOUT
  PASSWORD_CHANGE
  JWT_VALIDATION
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PAYMENT
  SALE
  INVOICE
  STOCK
  BACKUP
  SECURITY
  CREATE_PRODUCT
  UPDATE_PRODUCT
  DELETE_PRODUCT
  CREATE_CATEGORY
  UPDATE_CATEGORY
  DELETE_CATEGORY
  CREATE_STOCK
  UPDATE_STOCK
  DELETE_STOCK
  CREATE_TRANSFER
  UPDATE_TRANSFER
  DELETE_TRANSFER
  CREATE_PURCHASE
  UPDATE_PURCHASE
  DELETE_PURCHASE
  CREATE_RECEIPT
  UPDATE_RECEIPT
  DELETE_RECEIPT
  CREATE_QUOTE
  UPDATE_QUOTE
  DELETE_QUOTE
  CREATE_INVOICE
  UPDATE_INVOICE
  DELETE_INVOICE
  PRINT_INVOICE
  CREATE_PAYMENT
  UPDATE_PAYMENT
  DELETE_PAYMENT
  CREATE_CUSTOMER
  UPDATE_CUSTOMER
  DELETE_CUSTOMER
  CREATE_SUPPLIER
  UPDATE_SUPPLIER
  DELETE_SUPPLIER
  CREATE_USER
  UPDATE_USER
  DELETE_USER
  CREATE_STORE
  UPDATE_STORE
  DELETE_STORE
  CREATE_WAREHOUSE
  UPDATE_WAREHOUSE
  DELETE_WAREHOUSE
  CREATE_CASH_REGISTER
  UPDATE_CASH_REGISTER
  DELETE_CASH_REGISTER
  UPDATE_SETTINGS
  CREATE_POS_SALE
  DELETE_POS_SALE
}
enum NotificationType {
  INFO @map("info")
  SUCCESS @map("success")
  WARNING @map("warning")
  ERROR @map("error")
}

enum NotificationStatus {
  UNREAD @map("unread")
  READ @map("read")
  ARCHIVED @map("archived")
}

enum SupplierInvoiceStatus {
  DRAFT
  APPROVED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum SupplierPaymentMethod {
  CASH
  CREDIT
  CARD
  BANK_TRANSFER
  MIXED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  APPROVED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  RECEIVED
  CANCELLED
}

model Tenant {
  id String @id @default(cuid())
  name String
  slug String @unique
  address String?
  phone String?
  email String?
  currency String @default("HTG")
  timezone String @default("America/Port-au-Prince")
  language String @default("fr")
  businessCategory String?
  primaryActivity String?
  secondaryActivities String[] @default([])
  businessProfileType String?
  enabledBusinessModules String[] @default([])
  status TenantStatus @default(TRIAL)
  lastLoginAt DateTime?
  lastSeenAt DateTime?
  deletedAt DateTime?
  users User[]
  emailLogs EmailLog[]
  roles Role[]
  products Product[]
  warehouses Warehouse[]
  stores Store[]
  storeUsers StoreUser[]
  warehouseStocks WarehouseStock[]
  storeTransfersOut StoreTransfer[] @relation("StoreTransferFromTenant")
  storeTransfersIn StoreTransfer[] @relation("StoreTransferToTenant")
  inventoryMovements InventoryMovement[]
  inventoryAdjustments InventoryAdjustment[]
  sales Sale[]
  quotes Quote[]
  proformas Proforma[]
  invoices Invoice[]
  salesReturns SalesReturn[]
  customers Customer[]
  suppliers Supplier[]
  purchaseOrders PurchaseOrder[]
  goodsReceipts GoodsReceipt[]
  supplierInvoices SupplierInvoice[]
  supplierPayments SupplierPayment[]
  cashRegisters CashRegister[]
  cashSessions CashSession[]
  cashMovements CashMovement[]
  backupRecords BackupRecord[]
  securityLogs SecurityLog[]
  auditLogs AuditLog[]
  notifications Notification[]
  onboardingStates OnboardingState[]
  businessProfiles TenantBusinessProfile[]
  businessModules TenantBusinessModule[]
  transfersOut Transfer[] @relation("TransferFromTenant")
  transfersIn Transfer[] @relation("TransferToTenant")
  categories Category[]
  brands Brand[]
  units Unit[]
  settings TenantSettings?
  companyProfile CompanyProfile?
  logo TenantLogo?
  subscription TenantSubscription?
  subscriptionEvents SubscriptionEvent[]
  subscriptionPayments SubscriptionPayment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyProfile {
  id String @id @default(cuid())
  tenantId String @unique
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name String
  companyName String?
  industry String?
  website String?
  primaryColor String?
  secondaryColor String?
  logoUrl String?
  phone String?
  whatsapp String?
  email String?
  address String?
  city String?
  country String?
  taxNumber String?
  currency String @default("HTG")
  language String @default("fr")
  businessCategory String?
  primaryActivity String?
  secondaryActivities String[] @default([])
  businessProfileType String?
  enabledBusinessModules String[] @default([])
  timezone String @default("America/Port-au-Prince")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TenantSettings {
  id String @id @default(cuid())
  tenantId String @unique
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currency String @default("HTG")
  timezone String @default("America/Port-au-Prince")
  language String @default("fr")
  businessCategory String?
  primaryActivity String?
  secondaryActivities String[] @default([])
  businessProfileType String?
  enabledBusinessModules String[] @default([])
  taxEnabled Boolean @default(false)
  defaultTaxRate Decimal @default(0) @db.Decimal(5, 4)
  maxDiscountRate Decimal @default(0) @db.Decimal(5, 4)
  invoicePrefix String @default("INV")
  quotePrefix String @default("QUO")
  receiptPrefix String @default("RCT")
  posReceiptFormat String @default("80")
  invoiceFormat String @default("LETTER")
  allowNegativeStock Boolean @default(false)
  allowDiscount Boolean @default(true)
  requireCustomer Boolean @default(false)
  autoPrintReceipt Boolean @default(false)
  openCashDrawer Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TenantLogo {
  id String @id @default(cuid())
  tenantId String @unique
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url String?
  alt String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TenantSubscription {
  id String @id @default(cuid())
  tenantId String @unique
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @default(FREE)
  planId String?
  planRecord Plan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  status SubscriptionStatus @default(TRIALING)
  price Decimal @default(0) @db.Decimal(12, 2)
  currency String @default("HTG")
  paymentStatus String @default("UNPAID")
  startedAt DateTime @default(now())
  endsAt DateTime?
  trialStartedAt DateTime?
  trialEndsAt DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd DateTime?
  graceEndsAt DateTime?
  canceledAt DateTime?
  suspendedAt DateTime?
  events SubscriptionEvent[]
  payments SubscriptionPayment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
  @@index([status])
}

model Plan {
  id String @id @default(cuid())
  code String @unique
  name String
  description String?
  monthlyPrice Decimal @default(0) @db.Decimal(12, 2)
  currency String @default("HTG")
  trialDays Int @default(0)
  isActive Boolean @default(true)
  sortOrder Int @default(0)
  features PlanFeature[]
  subscriptions TenantSubscription[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model Feature {
  id String @id @default(cuid())
  key String @unique
  name String
  description String?
  category String
  plans PlanFeature[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model PlanFeature {
  id String @id @default(cuid())
  planId String
  featureId String
  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  enabled Boolean @default(true)
  limit Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, featureId])
  @@index([planId])
  @@index([featureId])
}

model SubscriptionEvent {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription TenantSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  actorUserId String?
  eventType String
  previousStatus SubscriptionStatus?
  newStatus SubscriptionStatus?
  metadata Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([eventType])
  @@index([createdAt])
}

model SubscriptionPayment {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription TenantSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount Decimal @db.Decimal(12, 2)
  currency String @default("HTG")
  status String @default("UNPAID")
  provider String @default("MANUAL")
  providerReference String?
  periodStart DateTime
  periodEnd DateTime
  paidAt DateTime?
  createdAt DateTime @default(now())

  @@unique([provider, providerReference])
  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
  @@index([paidAt])
}

model User {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email String
  name String
  password String
  isActive Boolean @default(true)
  roles UserRole[]
  profile UserProfile?
  onboardingStates OnboardingState[]
  passwordResetTokens PasswordResetToken[]
  emailLogs EmailLog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name String
  description String?
  isSystem Boolean @default(false)
  users UserRole[]
  permissions RolePermission[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id String @id @default(cuid())
  key String @unique
  name String
  category String
  description String?
  roles RolePermission[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([category])
}

model RolePermission {
  id String @id @default(cuid())
  roleId String
  permissionId String
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  id String @id @default(cuid())
  userId String
  roleId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}
model Category {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  imageUrl  String?
  icon      String?
  isActive  Boolean   @default(true)
  archivedAt DateTime?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Brand {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Unit {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  symbol    String
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, symbol])
  @@index([tenantId])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  size      String?
  model     String?
  capacity  String?
  sku       String?
  barcode   String?
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([sku])
  @@index([barcode])
}

model Product {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId     String?
  category       Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId        String?
  brand          Brand?         @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unitId         String?
  unit           Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  supplierId     String?
  supplier       Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  subCategory    String?
  reference      String?
  qrCode         String?
  promotionalPrice Decimal?     @db.Decimal(12, 2)
  taxRate        Decimal        @default(0) @db.Decimal(5, 4)
  maximumStock   Int            @default(0)
  location       String?
  storeId        String?
  warehouseId    String?
  manufacturingDate DateTime?
  expirationDate DateTime?
  warrantyMonths Int?
  sku            String
  name           String
  description    String?
  isActive       Boolean        @default(true)
  purchasePrice  Decimal        @default(0) @db.Decimal(12, 2)
  salePrice      Decimal        @default(0) @db.Decimal(12, 2)
  wholesalePrice Decimal        @default(0) @db.Decimal(12, 2)
  averageCost    Decimal        @default(0) @db.Decimal(12, 2)
  minimumStock   Int            @default(0)
  barcodes       Barcode[]
  priceHistory   PriceHistory[]
  images         ProductImage[]
  variants       ProductVariant[]
  stocks         Stock[]
  warehouseStocks WarehouseStock[]
  storeTransferItems StoreTransferItem[]
  movements      InventoryMovement[]
  adjustmentItems InventoryAdjustmentItem[]
  transferItems  TransferItem[]
  saleItems      SaleItem[]
  quoteItems     QuoteItem[]
  proformaItems  ProformaItem[]
  invoiceItems   InvoiceItem[]
  salesReturnItems SalesReturnItem[]
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceiptItems GoodsReceiptItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, isActive])
  @@index([tenantId, isActive, name])
  @@index([tenantId, isActive, createdAt])
  @@index([tenantId, supplierId])
  @@index([tenantId, expirationDate])
}

model Barcode {
  id        String      @id @default(cuid())
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  value     String
  type      BarcodeType @default(CUSTOM)
  isPrimary Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@unique([value])
  @@index([productId])
}

model PriceHistory {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchasePrice  Decimal  @db.Decimal(12, 2)
  salePrice      Decimal  @db.Decimal(12, 2)
  wholesalePrice Decimal  @db.Decimal(12, 2)
  averageCost    Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  @@index([productId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}
model Store {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String
  name      String
  phone     String?
  email     String?
  country   String?
  city      String?
  address   String?
  status    StoreStatus @default(ACTIVE)
  warehouses Warehouse[]
  users     StoreUser[]
  stocks    WarehouseStock[]
  transfersFrom StoreTransfer[] @relation("StoreTransferFromStore")
  transfersTo   StoreTransfer[] @relation("StoreTransferToStore")
  sales     Sale[]
  cashRegisters CashRegister[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
}

model StoreUser {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId    String
  role      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([storeId, userId])
  @@index([tenantId])
  @@index([storeId])
  @@index([userId])
}
model Warehouse {
  id        String              @id @default(cuid())
  tenantId  String
  storeId   String?
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store     Store?              @relation(fields: [storeId], references: [id], onDelete: SetNull)
  name      String
  code      String
  address   String?
  description String?
  status    WarehouseStatus     @default(ACTIVE)
  isActive  Boolean             @default(true)
  stocks    Stock[]
  warehouseStocks WarehouseStock[]
  movements InventoryMovement[]
  adjustments InventoryAdjustment[]
  transfersFrom Transfer[]       @relation("TransferFromWarehouse")
  storeTransfersFrom StoreTransfer[] @relation("StoreTransferFromWarehouse")
  transfersTo   Transfer[]       @relation("TransferToWarehouse")
  storeTransfersTo StoreTransfer[] @relation("StoreTransferToWarehouse")
  goodsReceipts GoodsReceipt[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([storeId])
}

model Stock {
  id        String    @id @default(cuid())
  tenantId  String
  productId String
  warehouseId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity  Int       @default(0)
  reserved  Int       @default(0)
  minimumStock Int    @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, productId, warehouseId])
  @@index([tenantId])
  @@index([productId])
  @@index([warehouseId])
}

model InventoryMovement {
  id          String                @id @default(cuid())
  tenantId    String
  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId   String
  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  type        InventoryMovementType
  userId      String?
  storeId     String?
  reason      String?
  quantity    Int
  beforeQty   Int
  afterQty    Int
  reference   String?
  note        String?
  createdAt   DateTime              @default(now())

  @@index([tenantId])
  @@index([productId])
  @@index([warehouseId])
  @@index([type])
  @@index([userId])
  @@index([storeId])
}

model PhysicalInventory {
  id          String                  @id @default(cuid())
  tenantId    String
  warehouseId String
  storeId     String?
  number      String
  status      PhysicalInventoryStatus @default(DRAFT)
  notes       String?
  createdById String?
  validatedById String?
  validatedAt DateTime?
  cancelledAt DateTime?
  items       PhysicalInventoryItem[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([warehouseId])
  @@index([storeId])
  @@index([status])
}

model PhysicalInventoryItem {
  id                  String            @id @default(cuid())
  physicalInventoryId String
  physicalInventory   PhysicalInventory @relation(fields: [physicalInventoryId], references: [id], onDelete: Cascade)
  productId           String
  systemQty           Int
  physicalQty         Int
  difference          Int
  barcode             String?
  notes               String?
  createdAt           DateTime          @default(now())

  @@index([physicalInventoryId])
  @@index([productId])
}

model StockAlert {
  id          String           @id @default(cuid())
  tenantId    String
  productId   String
  warehouseId String?
  storeId     String?
  type        StockAlertType
  status      StockAlertStatus @default(OPEN)
  message     String
  quantity    Int?
  threshold   Int?
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())
  resolvedAt  DateTime?

  @@index([tenantId])
  @@index([productId])
  @@index([warehouseId])
  @@index([storeId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model InventoryAdjustment {
