FROM node:20-alpine AS deps

WORKDIR /app

ARG BUILD_CACHE_BUST=local
RUN echo "Build cache bust: ${BUILD_CACHE_BUST}"

COPY package*.json ./
COPY apps ./apps
COPY packages ./packages
COPY database ./database

RUN npm ci

FROM node:20-alpine AS builder

WORKDIR /app

ARG NEXT_PUBLIC_API_URL=https://api.vtaerp.com
ARG NEXT_PUBLIC_BUILD_SHA
ARG NEXT_PUBLIC_BUILD_TIME
ARG BUILD_COMMIT_SHA
ARG BUILD_TIME
ARG COMMIT_SHA
ARG COOLIFY_GIT_COMMIT
ARG SOURCE_COMMIT
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_BUILD_SHA=${NEXT_PUBLIC_BUILD_SHA}
ENV NEXT_PUBLIC_BUILD_TIME=${NEXT_PUBLIC_BUILD_TIME}
ENV BUILD_COMMIT_SHA=${BUILD_COMMIT_SHA}
ENV BUILD_TIME=${BUILD_TIME}
ENV COMMIT_SHA=${COMMIT_SHA}
ENV COOLIFY_GIT_COMMIT=${COOLIFY_GIT_COMMIT}
ENV SOURCE_COMMIT=${SOURCE_COMMIT}

COPY --from=deps /app ./

RUN npm run build --workspace=@vta/web

FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ARG NEXT_PUBLIC_BUILD_SHA
ARG NEXT_PUBLIC_BUILD_TIME
ARG BUILD_COMMIT_SHA
ARG BUILD_TIME
ARG COMMIT_SHA
ARG COOLIFY_GIT_COMMIT
ARG SOURCE_COMMIT
ENV NEXT_PUBLIC_BUILD_SHA=${NEXT_PUBLIC_BUILD_SHA}
ENV NEXT_PUBLIC_BUILD_TIME=${NEXT_PUBLIC_BUILD_TIME}
ENV BUILD_COMMIT_SHA=${BUILD_COMMIT_SHA}
ENV BUILD_TIME=${BUILD_TIME}
ENV COMMIT_SHA=${COMMIT_SHA}
ENV COOLIFY_GIT_COMMIT=${COOLIFY_GIT_COMMIT}
ENV SOURCE_COMMIT=${SOURCE_COMMIT}

COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static

EXPOSE 3000

CMD ["node", "apps/web/server.js"]
